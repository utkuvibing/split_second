# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
.tools/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.cer
*.certSigningRequest

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS / OS
.DS_Store
Thumbs.db
*.pem

# --- Secrets & local environment (never commit) ---
.env
.env.*
!.env.example
.envrc
*.local

# Supabase local / CLI
supabase/.branches/
supabase/.temp/
**/supabase/.env
**/.supabase/

# Firebase / Google (if added later)
google-services.json
GoogleService-Info.plist

# EAS / credentials
credentials.json
secrets.json
*.credentials.json
AuthKey_*.p8
asc-api-key.p8

# IDE / editor local
.idea/
.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Test coverage
coverage/

# Misc local-only
*.backup
*.bak
.hermes/local/

# Supabase table backups (local audit snapshots)
data/backups/
