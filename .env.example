# Copy to .env and fill with your Supabase project values.
# Dashboard: Project Settings → API
# Never commit .env or paste service_role keys here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# Inventory apply only — set in .env (never commit real keys):
# SUPABASE_SERVICE_ROLE_KEY

# Optional: deploy batch RPC — set in .env:
# SUPABASE_DB_URL
